programa {
  inclua biblioteca Util --> u

  caracter jogo[3][3] = {{'_', '_', '_'},{'_', '_', '_'},{'_', '_', '_'}}, vencedor
  inteiro coluna, linha

  //INSTANCIAÇÃO DE FUNÇÃO PARA LER JOGADA DO X
  funcao jogadaX(){
    faca{
      escreva("\nEscolha uma linha de   1 a  3. ")
      leia(linha)
      escreva("\nEscolha uma coluna de   1 a  3. ")
      leia(coluna)
      limpa()
      se(jogo[linha-1][coluna-1]=='X' ou jogo[linha-1][coluna-1]=='O'){
        escreva("Espaço já utilizado, tente outro.")
      } senao {
        jogo[linha-1][coluna-1]='X'
        escreva("Jogada registrada com sucesso!")
      }
      u.aguarde(2000)
      limpa()
    }enquanto(jogo[linha-1][coluna-1]!='X' ou jogo[linha-1][coluna-1]!='O')
  }

  // FUNÇÃO PARA LERA JOGADA DO O
  funcao jogadaO(){
    faca{
      escreva("\nEscolha uma linha de   1 a  3. ")
      leia(linha)
      escreva("\nEscolha uma coluna de   1 a  3. ")
      leia(coluna)
      limpa()
      se(jogo[linha-1][coluna-1]=='X' ou jogo[linha-1][coluna-1]=='O'){
