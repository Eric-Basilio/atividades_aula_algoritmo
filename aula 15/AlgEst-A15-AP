      vencedor = jogo[2][0]
    } // VERIFICANDO VENCEDOR NA DIAGONAL CRESCENTE
    senao se(jogo[0][0]==jogo[1][1] e jogo[0][0]==jogo[2][2] e jogo[0][0] != '_'){
      escreva("O jogador ", jogo[0][0], " venceu essa partida.")
      vencedor = jogo[0][0]
    }
    

  }

  funcao inicio() {
    inteiro rodada = 0

    se(u.sorteia(1,2)==1){
      escreva("O jogador 'X' começa!")
    } senao  {
      escreva("O jogador 'O' começa!")
    }

    faca{

      rodada = rodada +1
    }enquanto(rodada<=9)


  }
