      vencedor = jogo[0][0]
    } //VERIFICANDO VENCEDOR NA SEGUNDA LINHA
    senao se(jogo[1][0] == jogo[1][1] e jogo[1][0] == jogo[1][2] e jogo[1][0] != '_'){
