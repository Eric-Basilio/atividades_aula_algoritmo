programa {
  funcao inicio() {
    cadeia nome, nacionalidade
    inteiro idade

    escreva("Olá, tudo bem? Como você se chama?\n")
    leia(nome)
    escreva("Legal, ", nome, "!")
    escreva("\nAgora me diz aí qual é a sua nacionalidade: ")
    leia(nacionalidade)
    escreva("\nCerto, agora me diz a sua idade: ")
    leia(idade)
    escreva("Você pode se apresentar")
    escreva("Boa noite, meu nome é ", nome, " sou ", nacionalidade,  " e tenho ", idade, " anos.")
  }
}
